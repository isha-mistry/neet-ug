generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
  schemas   = ["app", "staging"]
}

model College {
  collegeId            Int              @id @default(autoincrement()) @map("college_id")
  slug                 String           @unique
  name                 String
  stateSlug            String           @map("state_slug")
  city                 String?
  collegeType          String           @map("college_type")
  seatCount            Int              @default(0) @map("seat_count")
  quotaInfo            String           @default("") @map("quota_info")
  universityName       String?          @map("university_name")
  counselling          String?
  roi_score            Int              @default(50)
  bond_years           Int              @default(0)
  bond_penalty         Int              @default(0)
  bond_note            String?
  bed_count            Int              @default(0)
  patient_flow_per_day Int              @default(0)
  facilities           String[]         @default([])
  aliases              CollegeAlias[]
  states               states           @relation(fields: [stateSlug], references: [state_slug])
  cutoffs              cutoffs[]
  fee_schedules        fee_schedules[]
  seat_snapshots       seat_snapshots[]

  @@map("colleges")
  @@schema("app")
}

model CollegeAlias {
  aliasId   Int     @id @default(autoincrement()) @map("alias_id")
  collegeId Int     @map("college_id")
  source    String
  rawName   String  @map("raw_name")
  matchKey  String  @map("match_key")
  verified  Boolean @default(true)
  college   College @relation(fields: [collegeId], references: [collegeId], onDelete: Cascade)

  @@unique([source, rawName])
  @@map("college_aliases")
  @@schema("app")
}

model cutoffs {
  id                       Int      @id @default(autoincrement())
  college_id               Int
  year                     Int
  category                 String
  seat_type                String
  admission_round          String
  opening_rank_air         Int?
  closing_rank_air         Int?
  opening_state_merit_rank Decimal? @db.Decimal(12, 2)
  closing_state_merit_rank Decimal? @db.Decimal(12, 2)
  opening_neet_score       Int?
  closing_neet_score       Int?
  opening_percentile       Decimal? @db.Decimal(8, 5)
  closing_percentile       Decimal? @db.Decimal(8, 5)
  total_seats_filled       Int?
  opening_category_rank    String?
  closing_category_rank    String?
  colleges                 College  @relation(fields: [college_id], references: [collegeId], onDelete: Cascade)

  @@unique([college_id, year, category, seat_type, admission_round])
  @@index([college_id, year])
  @@index([year, category, closing_rank_air])
  @@schema("app")
}

model fee_line_items {
  id            Int           @id @default(autoincrement())
  schedule_id   Int
  component     String
  seat_type     String        @default("")
  category      String        @default("")
  amount        Decimal       @db.Decimal(14, 2)
  currency      String        @default("INR")
  period        String        @default("annual")
  fee_schedules fee_schedules @relation(fields: [schedule_id], references: [id], onDelete: Cascade)

  @@unique([schedule_id, component, seat_type, category])
  @@schema("app")
}

model fee_schedules {
  id             Int              @id @default(autoincrement())
  college_id     Int
  academic_year  Int
  source         String           @default("")
  fee_line_items fee_line_items[]
  colleges       College          @relation(fields: [college_id], references: [collegeId], onDelete: Cascade)

  @@unique([college_id, academic_year])
  @@schema("app")
}

model seat_buckets {
  id             Int            @id @default(autoincrement())
  snapshot_id    Int
  bucket_code    String
  seat_count     Int
  seat_snapshots seat_snapshots @relation(fields: [snapshot_id], references: [id], onDelete: Cascade)

  @@unique([snapshot_id, bucket_code])
  @@schema("app")
}

model seat_snapshots {
  id             Int            @id @default(autoincrement())
  college_id     Int
  academic_year  Int
  institute_type String
  total_seats    Int
  seat_buckets   seat_buckets[]
  colleges       College        @relation(fields: [college_id], references: [collegeId], onDelete: Cascade)

  @@unique([college_id, academic_year])
  @@schema("app")
}

model states {
  state_slug            String    @id
  name                  String
  intro                 String    @default("")
  total_seats           Int       @default(0)
  competition_level     String    @default("")
  fee_dimension_profile String    @default("seat_type")
  colleges              College[]

  @@schema("app")
}
