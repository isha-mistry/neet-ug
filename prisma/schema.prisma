generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
  schemas   = ["app"]
}

model State {
  stateSlug           String    @id @map("state_slug")
  name                String
  intro               String    @default("")
  totalSeats          Int       @default(0) @map("total_seats")
  competitionLevel    String    @default("") @map("competition_level")
  /// How fee rows are keyed for this state: seat_type, category, or both (import validation).
  feeDimensionProfile String    @default("seat_type") @map("fee_dimension_profile")
  colleges            College[]

  @@map("states")
  @@schema("app")
}

model College {
  collegeId           Int            @id @default(autoincrement()) @map("college_id")
  slug                String         @unique
  name                String
  stateSlug           String         @map("state_slug")
  city                String?
  collegeType         String         @map("college_type")
  seatCount           Int            @default(0) @map("seat_count")
  quotaInfo           String         @default("") @map("quota_info")
  universityName      String?        @map("university_name")
  counselling         String?
  roiScore            Int            @default(50) @map("roi_score")
  bondYears           Int            @default(0) @map("bond_years")
  bondPenalty         Int            @default(0) @map("bond_penalty")
  bondNote            String?        @map("bond_note")
  bedCount            Int            @default(0) @map("bed_count")
  patientFlowPerDay   Int            @default(0) @map("patient_flow_per_day")
  facilities          String[]       @default([])
  nirfInstitutionId String?        @map("nirf_institution_id")
  nirfMedicalRank   Int?           @map("nirf_medical_rank")
  nirfMedicalScore  Decimal?       @map("nirf_medical_score") @db.Decimal(5, 2)
  nirfRankingYear   Int?           @map("nirf_ranking_year")
  aliases             CollegeAlias[]
  state               State          @relation(fields: [stateSlug], references: [stateSlug])
  cutoffs             Cutoff[]
  feeSchedules        FeeSchedule[]
  seatSnapshots       SeatSnapshot[]

  @@map("colleges")
  @@schema("app")
}

model CollegeAlias {
  aliasId   Int     @id @default(autoincrement()) @map("alias_id")
  collegeId Int     @map("college_id")
  source    String
  rawName   String  @map("raw_name")
  matchKey  String  @map("match_key")
  verified  Boolean @default(true)
  college   College @relation(fields: [collegeId], references: [collegeId], onDelete: Cascade)

  @@unique([source, rawName])
  @@map("college_aliases")
  @@schema("app")
}

model FeeSchedule {
  id           Int           @id @default(autoincrement())
  collegeId    Int           @map("college_id")
  academicYear Int           @map("academic_year")
  source       String        @default("")
  lineItems    FeeLineItem[]
  college      College       @relation(fields: [collegeId], references: [collegeId], onDelete: Cascade)

  @@unique([collegeId, academicYear])
  @@map("fee_schedules")
  @@schema("app")
}

model FeeLineItem {
  id         Int         @id @default(autoincrement())
  scheduleId Int         @map("schedule_id")
  /// tuition | hostel | mess | university | transport | exam
  component  String
  /// GQ | MQ | NRI | … — empty string = all seat types
  seatType   String      @default("") @map("seat_type")
  /// OP | SC | ST | … — empty string = all categories
  category   String      @default("")
  amount     Decimal     @db.Decimal(14, 2)
  currency   String      @default("INR")
  /// annual | one_time
  period     String      @default("annual")
  schedule   FeeSchedule @relation(fields: [scheduleId], references: [id], onDelete: Cascade)

  @@unique([scheduleId, component, seatType, category])
  @@map("fee_line_items")
  @@schema("app")
}

model SeatSnapshot {
  id            Int          @id @default(autoincrement())
  collegeId     Int          @map("college_id")
  academicYear  Int          @map("academic_year")
  instituteType String       @map("institute_type")
  totalSeats    Int          @map("total_seats")
  buckets       SeatBucket[]
  college       College      @relation(fields: [collegeId], references: [collegeId], onDelete: Cascade)

  @@unique([collegeId, academicYear])
  @@map("seat_snapshots")
  @@schema("app")
}

model SeatBucket {
  id         Int          @id @default(autoincrement())
  snapshotId Int          @map("snapshot_id")
  /// aiq | state_quota | esic_ip | nri_quota | open | sc | st | obc | mbc | sebc | ews | mqt_quota | st_and_sa | obc_and_mbc | …
  bucketCode String       @map("bucket_code")
  seatCount  Int          @map("seat_count")
  snapshot   SeatSnapshot @relation(fields: [snapshotId], references: [id], onDelete: Cascade)

  @@unique([snapshotId, bucketCode])
  @@map("seat_buckets")
  @@schema("app")
}

model Cutoff {
  id                      Int      @id @default(autoincrement())
  collegeId               Int      @map("college_id")
  year                    Int
  category                String
  seatType                String   @map("seat_type")
  /// Counselling quota slice (e.g. GQ, OBC Quota). Empty for Gujarat-style rows.
  quota                   String   @default("")
  admissionRound          String   @map("admission_round")
  openingRankAir            Int?     @map("opening_rank_air")
  closingRankAir            Int?     @map("closing_rank_air")
  openingStateMeritRank     Decimal? @map("opening_state_merit_rank") @db.Decimal(12, 2)
  closingStateMeritRank     Decimal? @map("closing_state_merit_rank") @db.Decimal(12, 2)
  openingNeetScore          Int?     @map("opening_neet_score")
  closingNeetScore          Int?     @map("closing_neet_score")
  openingPercentile         Decimal? @map("opening_percentile") @db.Decimal(8, 5)
  closingPercentile         Decimal? @map("closing_percentile") @db.Decimal(8, 5)
  totalSeatsFilled          Int?     @map("total_seats_filled")
  openingCategoryRank       String?  @map("opening_category_rank")
  closingCategoryRank       String?  @map("closing_category_rank")
  college                   College  @relation(fields: [collegeId], references: [collegeId], onDelete: Cascade)

  @@unique([collegeId, year, category, seatType, admissionRound, quota])
  @@index([year, category, closingRankAir])
  @@index([collegeId, year])
  @@map("cutoffs")
  @@schema("app")
}

model Lead {
  id            String    @id @default(cuid())
  createdAt     DateTime  @default(now()) @map("created_at")
  formType      String    @map("form_type")
  status        String    @default("new")
  pagePath      String?   @map("page_path")
  pageLabel     String?   @map("page_label")
  variant       String?
  name          String?
  countryCode   String?   @default("+91") @map("country_code")
  phone         String?
  email         String?
  neetScore     Int?      @map("neet_score")
  neetCategory  String?   @map("neet_category")
  domicileState String?   @map("domicile_state")
  targetStates  String?   @map("target_states")
  city          String?
  queryType     String?   @map("query_type")
  message       String?
  preferredSlot String?   @map("preferred_slot")
  topics        Json?
  consent       Boolean   @default(false)
  consentAt     DateTime? @map("consent_at")
  rawPayload    Json?     @map("raw_payload")

  @@index([createdAt(sort: Desc)])
  @@index([formType])
  @@index([status])
  @@index([phone])
  @@map("leads")
  @@schema("app")
}

model NeetAnswerKey {
  id         Int     @id @default(autoincrement())
  year       Int     @default(2026)
  paperCode  String  @map("paper_code")
  questionNo Int     @map("question_no")
  answer     String
  subject    String

  @@unique([year, paperCode, questionNo])
  @@index([paperCode])
  @@map("neet_answer_keys")
  @@schema("app")
}

model NeetAnswerKeyPaper {
  id        Int     @id @default(autoincrement())
  year      Int     @default(2026)
  paperCode String  @map("paper_code")
  pdfUrl    String? @map("pdf_url")

  @@unique([year, paperCode])
  @@map("neet_answer_key_papers")
  @@schema("app")
}

