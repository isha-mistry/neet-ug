# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/
/dist/

# production
/build

# local DB dumps (may be large; never commit)
/data/dumps/
/data/Colleges_Images/

# catalog seed/import scripts (local ops; promote DB via scripts/db)
/scripts/catalog/
/scripts/db

# generated catalog spine (Postgres is runtime source of truth; local scripts may rewrite these)
/src/data/generated/colleges.json
/src/data/generated/states.json

# agent skills (local install via npx skills add; not shared in repo)
/.agents/
skills-lock.json
/.cursor/skills/

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Sentry Config File
.env.sentry-build-plugin
